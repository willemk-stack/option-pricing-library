"""Surface to local-vol to PDE workflow."""

direction: right

classes: {
  step: {
    style: {
      fill: transparent
      stroke-width: 1
      border-radius: 32
    }
  }

  accent: {
    style: {
      fill: transparent
      stroke: "#0F66B7"
      stroke-width: 2
      border-radius: 32
    }
  }

  result: {
    style: {
      fill: transparent
      stroke: "#3F7A4C"
      stroke-width: 2
      border-radius: 32
    }
  }
}

surface: "Surface inputs\nquotes or repaired SVI"
surface.class: step

repair: "Repair"
repair.class: step

handoff: "Smooth handoff"
handoff.class: accent

localvol: "Local-vol extract"
localvol.class: step

pde: "PDE validate"
pde.class: step

proof: "Proof outputs"
proof.class: result

surface -> repair
repair -> handoff
handoff -> localvol
localvol -> pde
pde -> proof
