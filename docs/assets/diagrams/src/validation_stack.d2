"""Validation stack diagram."""

direction: down

classes: {
  card: {
    style: {
      stroke-width: 2
      border-radius: 10
      shadow: true
    }
  }

  accent: {
    style: {
      stroke-width: 2
      border-radius: 10
      shadow: true
      fill-pattern: lines
    }
  }

  warm: {
    style: {
      stroke-width: 2
      border-radius: 12
      shadow: true
      fill-pattern: grain
    }
  }

  row: {
    style: {
      fill: transparent
      stroke: transparent
    }
  }
}

