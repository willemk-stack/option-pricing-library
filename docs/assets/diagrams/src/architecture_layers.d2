"""Layered architecture diagram."""

direction: right

classes: {
  card: {
    style: {
      stroke-width: 2
      border-radius: 10
      shadow: true
    }
  }

  accent: {
    style: {
      stroke-width: 2
      border-radius: 10
      shadow: true
    }
  }

  warm: {
    style: {
      stroke-width: 2
      border-radius: 12
      shadow: true
    }
  }

  row: {
    style: {
      fill: transparent
      stroke: transparent
    }
  }
}

interfaces: "Public interfaces\nspecs, instruments,\nmarket context"
interfaces.class: card

core_stack: "Core pricing stack\nvolatility, models,\nnumerics, pricers"
core_stack.class: accent

diagnostics: "Diagnostics\nsurface reports,\nrepricing audits"
diagnostics.class: warm

interfaces -> core_stack
core_stack -> diagnostics
