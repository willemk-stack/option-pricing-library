{
  "name": "option-pricing-docs-visual-tests",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:baseline": "playwright test pages.spec.ts",
    "test:update": "npm run test:update:all",
    "test:update:all": "playwright test sentinel.spec.ts pages.spec.ts components.spec.ts embedded-panels.spec.ts --update-snapshots",
    "test:update:sentinel": "playwright test sentinel.spec.ts --update-snapshots",
    "test:update:pages": "playwright test pages.spec.ts --update-snapshots",
    "test:update:components": "playwright test components.spec.ts --workers=1 --update-snapshots",
    "test:update:artifacts": "playwright test embedded-panels.spec.ts --update-snapshots",
    "test:a11y": "playwright test a11y.spec.ts",
    "test:smoke": "playwright test smoke.spec.ts",
    "test:audits": "playwright test dom-audits.spec.ts",
    "test:sentinel": "playwright test sentinel.spec.ts --max-failures=1",
    "test:components": "playwright test components.spec.ts --workers=1",
    "test:artifacts": "playwright test embedded-panels.spec.ts",
    "test:capture": "playwright test review-capture.spec.ts",
    "test:ci": "playwright test smoke.spec.ts dom-audits.spec.ts a11y.spec.ts pages.spec.ts components.spec.ts embedded-panels.spec.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "1.58.2",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
