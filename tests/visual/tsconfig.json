{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "ignoreDeprecations": "6.0",
        "moduleResolution": "Node",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "types": [
            "node",
            "@playwright/test"
        ],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "./**/*.ts"
    ]
}